"""
roundabout_abstraction.py
=========================
Build the decoupled 1-D MDP abstractions (longitudinal & lateral) for the
roundabout, compatible with FMTensJelmar's ``DFATree`` from
``dfa_tree_r1_risk_min.py``.

The roundabout is divided into **sections** (angular sectors) and **lanes**
(concentric rings).  The car's continuous state is expressed in Frenet
coordinates:

    s ∈ [0, L_section]    longitudinal progress within the current section
    d ∈ [-w/2, +w/2]      lateral deviation from lane centre-line

We discretise each axis independently into ``N_s`` and ``N_d`` grid cells
and build *deterministic* double-integrator transition matrices

    P_s:  (N_s, N_s * nu_s)      longitudinal
    P_d:  (N_d, N_d * nu_d)      lateral

where ``nu_s`` and ``nu_d`` are the numbers of acceleration inputs.

For the DFATree these are wrapped in lightweight ``SysAbs1D`` objects that
expose the same interface as ``MDPModel.P`` (a flat ``(N, N*nu)`` array) and
a ``.dim`` attribute equal to 1.

Label matrices
--------------
``L[d]`` has shape ``(n_letters, N_d)`` — one row per alphabet letter of the
DFA, one column per abstract state along dimension *d*.

    L[d][letter, i] = 1   if cell *i* on dimension *d* satisfies the
                           predicate for that letter.

For the longitudinal axis *s*, all interior cells satisfy 'r' (road); the
last cell(s) near ``s = L_section`` satisfy 't' (target, i.e.  the
section boundary where a DFA transition fires).

For the lateral axis *d*, cells within the drivable lane satisfy 'r'; cells
outside the lane boundaries satisfy 'n' (non-drivable).
"""

from __future__ import annotations

import math
from dataclasses import dataclass
from typing import Dict, List, Optional, Tuple

import numpy as np
from scipy.sparse import csr_matrix

# ---------------------------------------------------------------------------
# Lightweight 1-D system-abstraction wrapper
# ---------------------------------------------------------------------------

class SysAbs1D:
    """
    Minimal sysAbs wrapper for one decoupled dimension, compatible with
    ``DFATree._nu_of_dim`` and the 1-D path inside ``update_node_value``.

    Attributes
    ----------
    P        : np.ndarray (N, N*nu)  – flat transition matrix.
    P_flat   : alias for P.
    dim      : int = 1
    states   : np.ndarray (N, n_features)  – grid centres.
    hx       : list of 1-D axes arrays (length 1 for 1-D).
    l        : tuple of grid sizes (N,) – kept for compatibility.
    """

    def __init__(
        self,
        P_flat: np.ndarray,
        grid_centres: np.ndarray,
        hx: List[np.ndarray],
        inputs: np.ndarray,
    ) -> None:
        self.P = P_flat         # (N, N*nu)   – public alias
        self.P_flat = P_flat    # secondary alias
        self.dim = 1
        self.states = grid_centres
        self.hx = hx
        self.inputs = inputs
        N = P_flat.shape[0]
        nu = P_flat.shape[1] // N
        self.l = (N,)
        self.N = N
        self.nu = nu


# ---------------------------------------------------------------------------
# Helper: build 1-D deterministic transition matrix (double-integrator)
# ---------------------------------------------------------------------------

def _build_1d_double_integrator_transitions(
    N: int,
    x_min: float,
    x_max: float,
    dt: float,
    v_max: float,
    acc_values: np.ndarray,
    wrap: bool = False,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Build a deterministic 1-D transition matrix for a double-integrator
    discretised on position only (velocity is implicit via action).

    We consider a simplified single-integrator grid:
        x(k+1) = x(k) + v(k) * dt

    where v(k) is chosen from a set of discrete speed levels.
    For the roundabout:
      - longitudinal: speeds are forward (positive)
      - lateral: speeds are small corrections around 0

    Parameters
    ----------
    N          : number of grid cells
    x_min, x_max : axis extent
    dt         : time step [s]
    v_max      : maximum speed magnitude [m/s]
    acc_values : 1-D array of discrete action/speed values
    wrap       : if True, wrap around (for circular s-axis)

    Returns
    -------
    P_flat     : (N, N*nu) deterministic transition matrix
    centres    : (N,) cell centres
    inputs     : (nu,) input array
    """
    nu = len(acc_values)
    cell_width = (x_max - x_min) / N
    centres = np.linspace(x_min + cell_width / 2, x_max - cell_width / 2, N)

    P_flat = np.zeros((N, N * nu), dtype=float)

    for a_idx, v in enumerate(acc_values):
        for i in range(N):
            # next position under speed v
            x_next = centres[i] + v * dt
            
            if wrap:
                # Wrap around 
                x_next = x_min + (x_next - x_min) % (x_max - x_min)
            
            # Find nearest cell
            j = int(np.clip(round((x_next - centres[0]) / cell_width), 0, N - 1))
            P_flat[i, a_idx * N + j] = 1.0

    return P_flat, centres, acc_values


# ---------------------------------------------------------------------------
# Main builder
# ---------------------------------------------------------------------------

def build_roundabout_abstraction(
    section_arc_length: float,
    lane_width: float,
    n_lanes: int,
    n_sections: int,
    dt: float = 0.5,
    N_s: int = 20,
    N_d: int = 10,
    v_s_max: float = 10.0,
    v_d_max: float = 2.0,
    n_speed_levels_s: int = 5,
    n_speed_levels_d: int = 5,
    target_section: int = 8,
    exit_lane: int = 3,
    target_s_frac: float = 0.8,
    dfa_n_letters: int = 4,
) -> Dict:
    """
    Build all objects needed by DFATree for the decoupled roundabout MDP.

    Returns
    -------
    dict with keys:
        'sysAbs'    : [SysAbs1D, SysAbs1D]   (longitudinal, lateral)
        'nx_list'   : [N_s, N_d]
        'L'         : [L_s, L_d]              label matrices (n_letters, N_d)
        'pol'       : initial uniform policy array
        'rho'       : initial rho (uniform distribution)
        'cost_map'  : [cost_s, cost_d]        per-cell costs per dimension
        'centres_s' : (N_s,) array of s-axis centres
        'centres_d' : (N_d,) array of d-axis centres
        'acc_s'     : longitudinal speed actions
        'acc_d'     : lateral speed actions
    """
    # ---- Longitudinal axis ----
    s_min, s_max = 0.0, section_arc_length
    acc_s = np.linspace(0.0, v_s_max, n_speed_levels_s)  # forward speeds only
    
    P_s, centres_s, inputs_s = _build_1d_double_integrator_transitions(
        N=N_s, x_min=s_min, x_max=s_max, dt=dt,
        v_max=v_s_max, acc_values=acc_s, wrap=True,
    )
    hx_s = [centres_s]
    sysAbs_s = SysAbs1D(P_s, centres_s.reshape(-1, 1), hx_s, inputs_s)

    # ---- Lateral axis ----
    d_min = -lane_width / 2.0
    d_max =  lane_width / 2.0
    acc_d = np.linspace(-v_d_max, v_d_max, n_speed_levels_d)
    
    P_d, centres_d, inputs_d = _build_1d_double_integrator_transitions(
        N=N_d, x_min=d_min, x_max=d_max, dt=dt,
        v_max=v_d_max, acc_values=acc_d, wrap=False,
    )
    hx_d = [centres_d]
    sysAbs_d = SysAbs1D(P_d, centres_d.reshape(-1, 1), hx_d, inputs_d)

    sysAbs_list = [sysAbs_s, sysAbs_d]
    nx_list = [N_s, N_d]

    # ---- Label matrices ----
    # DFA letters: 0='r', 1='t', 2='n', 3='c'
    # L[d] shape: (n_letters, N_d)

    # Longitudinal labels
    L_s = np.zeros((dfa_n_letters, N_s), dtype=float)
    target_s_idx = int(N_s * target_s_frac)
    # Road label (letter 0='r'): all cells
    L_s[0, :] = 1.0
    # Target label (letter 1='t'): cells near section boundary
    L_s[1, target_s_idx:] = 1.0
    # Non-drivable (letter 2='n'): none on s-axis
    L_s[2, :] = 0.0
    # Collision (letter 3='c'): none initially (dynamic)
    L_s[3, :] = 0.0

    # Lateral labels
    L_d = np.zeros((dfa_n_letters, N_d), dtype=float)
    # Determine which cells are within the drivable lane
    half_w = lane_width / 2.0
    margin = lane_width * 0.1  # 10% margin for "non-drivable"
    for i, d_val in enumerate(centres_d):
        if abs(d_val) <= (half_w - margin):
            # Safely within lane
            L_d[0, i] = 1.0  # road
        else:
            # Near or beyond lane boundary → non-drivable
            L_d[2, i] = 1.0  # non-drivable
    # Target on d-axis: centre of lane is fine (handled by s-axis)
    # Just mark centre cells as also eligible for target
    centre_band = N_d // 4
    mid = N_d // 2
    L_d[1, max(0, mid - centre_band):min(N_d, mid + centre_band + 1)] = 1.0
    # Collision: empty initially
    L_d[3, :] = 0.0

    L_list = [L_s, L_d]

    # ---- Uniform initial policy ----
    n_dfa_states = 3  # from RoundaboutDFA
    nu_s = len(acc_s)
    nu_d = len(acc_d)

    pol = np.empty((n_dfa_states, 2), dtype=object)
    for q in range(n_dfa_states):
        pol[q, 0] = csr_matrix(np.full((N_s, nu_s), 1.0 / nu_s))
        pol[q, 1] = csr_matrix(np.full((N_d, nu_d), 1.0 / nu_d))

    # ---- rho: uniform initial state distribution ----
    rho = [np.ones(N_s) / N_s, np.ones(N_d) / N_d]

    # ---- Cost maps (per dimension) ----
    # Longitudinal: zero cost everywhere (driving is fine)
    cost_s = np.zeros(N_s, dtype=float)

    # Lateral: penalise being far from lane centre
    # c(d) = k * |d|  (incentivise lane centering)
    cost_d = np.abs(centres_d) / half_w  # normalised 0..1
    cost_d = cost_d * 10.0  # scale factor

    cost_map = [cost_s, cost_d]

    return {
        'sysAbs': sysAbs_list,
        'nx_list': nx_list,
        'L': L_list,
        'pol': pol,
        'rho': rho,
        'cost_map': cost_map,
        'centres_s': centres_s,
        'centres_d': centres_d,
        'acc_s': acc_s,
        'acc_d': acc_d,
    }


def frenet_to_cell_indices(
    s: float, d: float,
    centres_s: np.ndarray,
    centres_d: np.ndarray,
) -> Tuple[int, int]:
    """Map continuous Frenet (s, d) to nearest grid cell indices."""
    cell_w_s = centres_s[1] - centres_s[0] if len(centres_s) > 1 else 1.0
    cell_w_d = centres_d[1] - centres_d[0] if len(centres_d) > 1 else 1.0

    i_s = int(np.clip(round((s - centres_s[0]) / cell_w_s), 0, len(centres_s) - 1))
    i_d = int(np.clip(round((d - centres_d[0]) / cell_w_d), 0, len(centres_d) - 1))
    return i_s, i_d


def cell_indices_to_frenet(
    i_s: int, i_d: int,
    centres_s: np.ndarray,
    centres_d: np.ndarray,
) -> Tuple[float, float]:
    """Map grid cell indices back to Frenet (s, d) coordinates."""
    return float(centres_s[i_s]), float(centres_d[i_d])
